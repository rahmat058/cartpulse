# CartPulse — Next.js E-commerce
# Copy to .env and fill in values: cp .env.example .env

# Database
DATABASE_URL="postgresql://ronodev@localhost:5432/cartpulse"

# Production Cloud Prisma Database URL (demo — replace with your cloud provider URL)
# DATABASE_URL="postgresql://user:password@db.example.prisma.io:5432/cartpulse?sslmode=require"

# Auth (NextAuth v5) — generate: openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Public origin for Stripe success/cancel URLs (defaults to AUTH_URL)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google OAuth (optional — enables "Sign in with Google")
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web)
# Authorized JavaScript origins:  http://localhost:3000
# Authorized redirect URI:        http://localhost:3000/api/auth/callback/google
# Production — replace localhost with your domain, e.g. https://cartpulse.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=<GOOGLE_CLIENT_ID Paste Here>
GOOGLE_CLIENT_SECRET=<GOOGLE_CLIENT_SECRET Past Here>

# GitHub OAuth (optional)
# Authorized callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=<GITHUB_CLIENT_ID Paste Here>
GITHUB_CLIENT_SECRET=<GITHUB_CLIENT_SECRET Paste Here>

# Stripe — hosted Checkout (redirect to stripe.com)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Email (Resend — required for verification & password reset)
RESEND_API_KEY=
EMAIL_FROM="CartPulse <onboarding@resend.dev>"
ADMIN_EMAIL=

# Cloudinary (optional — product image upload)
# Easiest: copy the full "API environment variable" from Cloudinary dashboard:
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=
CLOUDINARY_FOLDER=cartpulse
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
