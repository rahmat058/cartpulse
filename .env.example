# CartPulse — Next.js E-commerce
# Copy to .env and fill in values:
#   macOS/Linux:  cp .env.example .env
#   Windows:      copy .env.example .env

# =============================================================================
# Database (Prisma Postgres)
# =============================================================================
# Two URLs — both required for `yarn dev` and production:
#
#   DATABASE_URL             Direct TCP (postgres://…)
#                            Used by: prisma migrate, db push, db:reset, db:seed
#                            Config:  prisma.config.ts
#
#   DATABASE_ACCELERATE_URL  Accelerate (prisma+postgres://…)
#                            Used by: app runtime — lib/prisma.ts (pool + cacheStrategy)
#                            From:    Prisma dashboard → your database → Connect → Accelerate
#
# Local PostgreSQL — pick ONE platform block below (comment out the other).
# URL-encode special characters in passwords (e.g. $ → %24, @ → %40).
#
# --- macOS (Homebrew PostgreSQL@14) ---
# Default user is your macOS username; database name: cartpulse
# DATABASE_URL="postgresql://YOUR_MAC_USERNAME@localhost:5432/cartpulse"
#
# --- Windows (PostgreSQL@18) ---
# Default superuser: postgres; database name: cartpulse
# DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/cartpulse"
#
# --- Prisma Postgres cloud (recommended for dev + deploy) ---
# Direct TCP — migrations / CLI (Prisma dashboard → Connect → TCP)
DATABASE_URL="postgres://USER:PASSWORD@pooled.db.prisma.io:5432/postgres?sslmode=require"
#
# Accelerate — app runtime (Prisma dashboard → Connect → Accelerate)
DATABASE_ACCELERATE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_ACCELERATE_API_KEY"

# =============================================================================
# Auth (NextAuth v5)
# =============================================================================
# Generate AUTH_SECRET: openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Public origin for Stripe success/cancel URLs (defaults to AUTH_URL in code)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# =============================================================================
# Google OAuth (optional — enables "Sign in with Google")
# =============================================================================
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web)
# Authorized JavaScript origins:  http://localhost:3000
# Authorized redirect URI:        http://localhost:3000/api/auth/callback/google
# Production — replace localhost with your domain, e.g. https://your-app.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# GitHub OAuth (optional)
# =============================================================================
# Authorized callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# =============================================================================
# Stripe (optional — demo checkout works without keys)
# =============================================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# =============================================================================
# Email (Resend — required for verification & password reset)
# =============================================================================
RESEND_API_KEY=
EMAIL_FROM="CartPulse <onboarding@resend.dev>"
ADMIN_EMAIL=

# =============================================================================
# Cloudinary (optional — product image upload)
# =============================================================================
# Easiest: copy the full "API environment variable" from Cloudinary dashboard:
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=
CLOUDINARY_FOLDER=cartpulse
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
