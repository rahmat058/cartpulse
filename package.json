{
  "name": "cartpulse",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.11.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push && prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "node --import tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:test": "node --import tsx scripts/test-database.ts",
    "db:reset": "node --import tsx scripts/db-reset.ts",
    "generate:data": "node scripts/generate-products.mjs",
    "postinstall": "prisma generate"
  },
  "dependencies": {
